# Dashboard Authentication
AUTH_USER=admin
AUTH_PASS=secret

# Client Branding (shown in navbar)
CLIENT_NAME=PT Example Corp

# GoPhish API Connection
GOPHISH_API_KEY=your_api_key_here
GOPHISH_SERVER_URL=https://172.17.0.1:3333

# Optional: IP Geolocation (ipinfo.io token)
IPINFO_TOKEN=

# Dashboard Port (for docker-compose)
DASHBOARD_PORT=51337
